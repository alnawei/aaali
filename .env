# ==================== Telegram 机器人配置 ====================
# 向 @BotFather 申请的 Bot Token
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# 你的个人 Telegram User ID (可通过 @userinfobot 获取)，填错将拒绝响应！
ADMIN_ID=12345678

# ==================== 阿里云 API 访问凭证 ====================
# 建议在阿里云 RAM 访问控制中创建一个子账号，并赋予 ECS 和 CMS(云监控) 权限
ALIYUN_ACCESS_KEY_ID=LTAI5txxxxxxxxxxxxxx
ALIYUN_ACCESS_KEY_SECRET=x82Abcxxxxxxxxxxxxxxxxxxxxxx

# ==================== Resend 邮件服务配置 ====================
# 去 resend.com 申请的 API Key
RESEND_API_KEY=re_123456789_abcdefg
# 接收开服验证码的邮箱 (注意：如果使用测试发件源，这里必须填你注册 Resend 时用的邮箱)
RECIPIENT=your_email@domain.com

# ==================== 阿里云 ECS 启动模板 ID (可选) ====================
# 如果你想通过 .env 静态配置启动模板，按以下格式填写：
# 命名规则：TPL_ + 地域ID大写(短横线替换为下划线)
TPL_CN_HONGKONG=lt-bp1xxxxxxxxxxxxxx
TPL_AP_NORTHEAST_1=lt-0xjxxxxxxxxxxxxxx

